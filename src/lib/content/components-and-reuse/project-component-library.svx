<script>
	import { CodeBlock, Callout, Quiz, ProjectBrief } from '$lib/components/lesson';

	const S = '<' + 'script';
	const E = '<' + '/script>';

	const badge = `${S} lang="ts">
  import { cn } from '$lib/utils/cn';
  import type { Snippet } from 'svelte';
  type Tone = 'neutral' | 'success' | 'warning' | 'danger';
  let { children, tone = 'neutral', class: className = '' }:
    { children: Snippet; tone?: Tone; class?: string } = $props();

  const tones: Record<Tone, string> = {
    neutral: 'bg-slate-100 text-slate-700',
    success: 'bg-emerald-100 text-emerald-700',
    warning: 'bg-amber-100 text-amber-700',
    danger: 'bg-red-100 text-red-700'
  };
${E}

<span class={cn('inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium', tones[tone], className)}>
  {@render children()}
</span>`;

	const card = `${S} lang="ts">
  import { cn } from '$lib/utils/cn';
  import type { Snippet } from 'svelte';
  let { children, class: className = '' }:
    { children: Snippet; class?: string } = $props();
${E}

<div class={cn('rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900', className)}>
  {@render children()}
</div>`;

	const alert = `${S} lang="ts">
  import { cn } from '$lib/utils/cn';
  import type { Snippet } from 'svelte';
  type Tone = 'info' | 'success' | 'danger';
  let { children, tone = 'info' }: { children: Snippet; tone?: Tone } = $props();

  const tones: Record<Tone, string> = {
    info: 'border-sky-300 bg-sky-50 text-sky-800',
    success: 'border-emerald-300 bg-emerald-50 text-emerald-800',
    danger: 'border-red-300 bg-red-50 text-red-800'
  };
${E}

<div role="alert" class={cn('rounded-lg border-l-4 p-4 text-sm', tones[tone])}>
  {@render children()}
</div>`;
</script>

# Project: Component Library

Time to consolidate Module 7 into a small, typed, cohesive component library — the kind you'd
actually drop into a real SvelteKit app. You'll apply the variant pattern, `cn()` composition, and
snippet-based content across four primitives.

<ProjectBrief
	title="Build a typed component library"
	time="55 min"
	goal="Create Button, Badge, Card and Alert as typed Svelte 5 components that share a cn() helper, expose orthogonal variant props, accept className overrides, and support dark mode."
	requirements={[
		'A shared cn() utility in $lib/utils',
		'Button with intent + size variants (from the previous lesson)',
		'Badge with a tone variant',
		'Card as a styled container accepting children + class override',
		'Alert with role="alert" and tone variants',
		'Every component accepts a `class` prop merged via cn()'
	]}
	stretch={[
		'Add an icon slot to Button and Alert',
		'Add a loading state to Button',
		'Write a Vitest test asserting the right classes per variant'
	]}
/>

