<script>
	import { CodeBlock, Callout, Quiz, ProjectBrief } from '$lib/components/lesson';

	const stepperLogic = `<` + `script lang="ts">
  let step = $state(1);
  const total = 3;
  const next = () => (step = Math.min(step + 1, total));
  const back = () => (step = Math.max(step - 1, 1));
<` + `/script>

<div class="mx-auto max-w-md rounded-2xl bg-white p-6 shadow-lg">
  <!-- progress -->
  <div class="mb-6 flex items-center gap-2">
    {#each Array(total) as _, i}
      <div class="h-1.5 flex-1 rounded-full {i < step ? 'bg-indigo-600' : 'bg-slate-200'}"></div>
    {/each}
  </div>

  {#if step === 1}
    <h2 class="text-lg font-semibold">Your details</h2>
    <!-- step 1 fields -->
  {:else if step === 2}
    <h2 class="text-lg font-semibold">Your plan</h2>
    <!-- step 2 fields -->
  {:else}
    <h2 class="text-lg font-semibold">Review</h2>
    <!-- summary -->
  {/if}

  <div class="mt-6 flex justify-between">
    <button onclick={back} disabled={step === 1}
      class="rounded-lg px-4 py-2 text-slate-600 disabled:opacity-40">Back</button>
    <button onclick={next}
      class="rounded-lg bg-indigo-600 px-4 py-2 font-medium text-white">
      {step === total ? 'Submit' : 'Continue'}
    </button>
  </div>
</div>`;
</script>

# Project: Multi-Step Form

Multi-step forms reduce overwhelm by chunking a long flow into digestible steps. You'll combine
Svelte 5 state with everything from this module: clean inputs, validation states, accessible labels,
and a progress indicator.

<ProjectBrief
	title="Build an accessible multi-step signup"
	time="50 min"
	goal="Create a three-step signup (details → plan → review) with a progress bar, Back/Continue navigation driven by Svelte 5 runes, validated and accessible inputs, and a final review step."
	requirements={[
		'A progress indicator showing current step of total',
		'Step state managed with a Svelte 5 $state rune',
		'Back/Continue buttons; Back disabled on step 1, Submit label on the last step',
		'Accessible, labelled, validated inputs on each step',
		'A review step summarising the entered data'
	]}
	stretch={[
		'Block Continue until the current step is valid',
		'Animate step transitions (preview of Module 8)',
		'Persist progress to localStorage so a refresh resumes'
	]}
/>

